    "import shutil\n",
    "\n",
    "zip_path = './download_lists.zip'\n",
    "shutil.make_archive('./download_lists', 'zip', output_dir)\n",
    "\n",
    "files.download(zip_path)\n",
    "print('✅ Téléchargement lancé !')"
   ],
